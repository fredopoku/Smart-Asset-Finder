# Smart Asset Finder — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

APP_ENV=development
APP_URL=http://localhost/Smart-Asset-Finder/

DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=lfis_db

# ── Mail / SMTP ──────────────────────────────────────────────────────────────
# Driver: "smtp" (recommended for production) or "mail" (PHP mail())
MAIL_DRIVER=smtp

# SMTP server — Gmail example (use App Password, not your real Gmail password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here

# Sender details shown in the From: field
MAIL_FROM_ADDRESS=no-reply@smartassetfinder.com
MAIL_FROM_NAME=Smart Asset Finder

# App display name used in email templates
APP_NAME=Smart Asset Finder
